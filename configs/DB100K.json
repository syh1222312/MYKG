{
	"dataset": "DB100K",
	"model_name": "ConvD",
	"model_hyper_params": {
		"emb_dim": 400,
		"reshape": [20, 20],
		"conv_out_channels": 50,
		"conv_kernel_size": [4, 4],
		"stride": 1,
		"input_dropout": 0.1,
		"feature_map_dropout": 0.4,
		"hidden_dropout": 0.2,
		"q_size": [100, 100],
		"k_size": [2500, 100],
		"v_size": [2500, 100],
		"a": 0.1,
		"b": 0.05,
		"memory_size": 1000,
		"label_smoothing": 0.1,
		"use_bias": true
	},
	"optimizer": {
		"algorithm": "adam",
		"lr": 0.003,
		"weight_decay": 0
	},
	"train": {
		"batch_size": 128,
		"epochs": 10,
		"seed": 123,
		"pretrain_model": null
	},
	"eval": {
		"do_validate": true,
		"do_test": true,
		"valid_steps": 1,
		"batch_size": 128,
		"eval_func": "eval_for_tail"
	},
	"seed": 123,
	"save_model_path": "./output"
}
